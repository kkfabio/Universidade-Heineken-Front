<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Dashboard UHNK</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      display: flex;
      background: #f5f5f5;
    }

    /* SIDEBAR */
    .sidebar {
      width: 220px;
      height: 100vh;
      background: #145c2c;
      color: white;
      padding: 20px;
    }

    .sidebar h2 {
      font-size: 14px;
      margin-bottom: 30px;
    }

    .menu {
      list-style: none;
    }

    .menu li {
      padding: 12px;
      margin: 10px 0;
      cursor: pointer;
      border-radius: 6px;
    }

    .menu li:hover {
      background: #1c7a3c;
    }

    .ask-ai {
      position: absolute;
      bottom: 20px;
      left: 20px;
      right: 20px;
      background: #1c7a3c;
      padding: 10px;
      text-align: center;
      border-radius: 6px;
    }

    /* MAIN */
    .main {
      flex: 1;
      padding: 20px;
    }

    /* HEADER */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .header h1 {
      color: #145c2c;
    }

    /* HERO */
    .hero {
      background: #1c7a3c;
      color: white;
      padding: 30px;
      border-radius: 15px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .hero h2 {
      font-size: 32px;
      margin-bottom: 10px;
    }

    .hero p {
      font-size: 14px;
      opacity: 0.9;
    }

    .certificate-img {
      width: 120px;
      height: 150px;
      background: #eee;
      border-radius: 10px;
    }

    /* CONTENT */
    .content {
      display: flex;
      gap: 20px;
    }

    .left {
      flex: 2;
    }

    .right {
      flex: 1;
    }

    /* MODULE CARD */
    .module {
      background: white;
      padding: 15px;
      border-radius: 10px;
      margin-bottom: 15px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .module span {
      font-size: 12px;
      color: gray;
    }

    /* CERTIFICATE CARD */
    .card {
      background: white;
      padding: 20px;
      border-radius: 15px;
      text-align: center;
      margin-bottom: 20px;
    }

    .card h3 {
      margin-bottom: 10px;
    }

    .btn {
      background: #1c7a3c;
      color: white;
      padding: 12px;
      border-radius: 8px;
      margin-top: 10px;
      display: block;
      text-decoration: none;
    }

    .btn-secondary {
      background: #ddd;
      color: #333;
    }

    /* NEXT STEP */
    .next {
      background: #1c7a3c;
      color: white;
      padding: 20px;
      border-radius: 12px;
    }

  </style>
</head>
<body>

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h2>Learning Journey</h2>
    <ul class="menu">
      <li>Feed</li>
      <li>Cursos</li>
      <li>Wiki</li>
      <li>Certificados</li>
      <li>Perfil</li>
    </ul>

    <div class="ask-ai">Ask AI</div>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- HEADER -->
    <div class="header">
      <h1>UHNK</h1>
      <div>⚙️ 👤</div>
    </div>

    <!-- HERO -->
    <div class="hero">
      <div>
        <h2>Você é agora um Especialista Global!</h2>
        <p>Completou com êxito o curso de Maestria em Logística Sustentável.</p>
      </div>
      <div class="certificate-img"></div>
    </div>

    <!-- CONTENT -->
    <div class="content">

      <!-- LEFT -->
      <div class="left">
        <h3>Conteúdo Concluído</h3>

        <div class="module">
          <div>
            <strong>Módulo 01</strong><br>
            Introdução à Cadeia de Suprimentos
          </div>
          <span>12 aulas</span>
        </div>

        <div class="module">
          <div>
            <strong>Módulo 02</strong><br>
            Redução de Carbono em Transportes
          </div>
          <span>8 aulas</span>
        </div>

        <div class="module">
          <div>
            <strong>Módulo 03</strong><br>
            Ética e Compliance Ambiental
          </div>
          <span>15 aulas</span>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="right">

        <div class="card">
          <h3>Certificado de Conclusão</h3>
          <p><strong>João Silva Pereira</strong></p>
          <a href="#" class="btn">Acessar meu Certificado</a>
          <a href="#" class="btn btn-secondary">Explorar mais cursos</a>
        </div>

        <div class="next">
          <h4>Próximo Passo</h4>
          <p>Recomendamos o curso Inovação Tática em Distribuição</p>
        </div>

      </div>

    </div>

  </div>

</body>
</html>