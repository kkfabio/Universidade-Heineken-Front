<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<title>Wiki - Heineken</title>

<style>
:root {
  --green-dark: #0f3d1f;
  --green: #166534;
  --green-light: #22c55e;
  --bg: #f6f8f7;
  --card: #ffffff;
  --text: #1f2937;
  --muted: #6b7280;
}

/* RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Poppins", sans-serif;
}

body {
  display: flex;
  background: var(--bg);
}

/* SIDEBAR */
.sidebar {
  width: 240px;
  height: 100vh;
  background: linear-gradient(180deg, #0f3d1f, #166534);
  color: white;
  padding: 25px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.menu {
  list-style: none;
}

.menu li {
  padding: 12px;
  border-radius: 10px;
  margin-bottom: 10px;
  display: flex;
  gap: 10px;
  cursor: pointer;
  transition: 0.2s;
}

.menu li.active {
  background: rgba(255,255,255,0.15);
}

.menu li:hover {
  background: rgba(255,255,255,0.1);
}

.ask-ai {
  background: var(--green-light);
  padding: 12px;
  text-align: center;
  border-radius: 10px;
  font-weight: 500;
}

/* MAIN */
.main {
  flex: 1;
  padding: 40px;
}

/* HEADER */
.header small {
  color: var(--green);
  letter-spacing: 2px;
  font-weight: 600;
}

.header h1 {
  font-size: 42px;
  margin: 10px 0;
}

.header p {
  color: var(--muted);
  max-width: 600px;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 25px;
  margin-top: 30px;
}

/* CARD */
.card {
  background: var(--card);
  border-radius: 20px;
  padding: 22px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}

/* HISTÓRIA */
.history {
  display: flex;
  padding: 0;
  overflow: hidden;
}

.history-img {
  width: 45%;
  background: linear-gradient(135deg, #0f3d1f, #166534);
}

.history-content {
  padding: 25px;
}

.tag {
  font-size: 12px;
  color: var(--green);
  font-weight: 600;
}

.badge {
  background: #e6f9ec;
  color: var(--green);
  padding: 5px 10px;
  border-radius: 999px;
  font-size: 11px;
  margin-left: 10px;
}

.link {
  display: inline-block;
  margin-top: 10px;
  color: var(--green);
  font-weight: 500;
}

/* CULTURA */
.culture {
  background: linear-gradient(135deg, #166534, #0f3d1f);
  color: white;
}

/* SUSTENTABILIDADE */
.sustain img {
  width: 100%;
  border-radius: 12px;
}

.sustain h3 {
  margin-top: 10px;
}

/* PROCESSO (DIVIDIDO PROFISSIONAL) */
.process {
  display: flex;
  padding: 0;
  overflow: hidden;
  border-radius: 20px;
}

.process-left {
  flex: 1;
  padding: 25px;
}

.process-right {
  width: 40%;
  background: #eef2f1;
  border-left: 1px solid #e5e7eb;
}

/* STEPS */
.steps {
  margin: 20px 0;
}

.step {
  display: flex;
  gap: 12px;
  margin-bottom: 18px;
}

.number {
  color: var(--green);
  font-weight: 600;
}

.step strong {
  display: block;
}

.step p {
  font-size: 12px;
  color: var(--muted);
}

/* BOTÕES */
.btn {
  padding: 10px 16px;
  border-radius: 10px;
  border: 1px solid var(--green);
  background: transparent;
  color: var(--green);
  cursor: pointer;
  font-weight: 500;
}

.btn-primary {
  background: var(--green);
  color: white;
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--green);
}

/* FOOTER */
.footer {
  text-align: center;
  margin-top: 50px;
}

.quote {
  font-style: italic;
  color: var(--muted);
  margin-bottom: 15px;
}

/* RESPONSIVO */
@media(max-width: 900px){
  .grid {
    grid-template-columns: 1fr;
  }

  .sidebar {
    display: none;
  }

  .history {
    flex-direction: column;
  }

  .history-img {
    width: 100%;
    height: 150px;
  }

  .process {
    flex-direction: column;
  }

  .process-right {
    display: none;
  }
}
</style>
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <ul class="menu">
    <li><i class="fa fa-home"></i> Feed</li>
    <li><i class="fa fa-book"></i> Courses</li>
    <li class="active"><i class="fa fa-wikipedia-w"></i> Wiki</li>
    <li><i class="fa fa-certificate"></i> Certificates</li>
    <li><i class="fa fa-user"></i> Profile</li>
  </ul>

  <div class="ask-ai">Ask AI</div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- HEADER -->
  <div class="header">
    <small>KNOWLEDGE REPOSITORY</small>
    <h1>Wiki — Conheça a Heineken</h1>
    <p>Explore deeper into our legacy, processes and values.</p>
  </div>

  <!-- GRID -->
  <div class="grid">

    <!-- LEFT -->
    <div>

      <div class="card history">
        <div class="history-img"></div>
        <div class="history-content">
          <span class="tag">LEGADO</span>
          <span class="badge">DESTAQUE</span>
          <h2>História</h2>
          <p>Desde 1864, de uma pequena cervejaria em Amsterdã para o mundo.</p>
          <span class="link">Ler artigo completo →</span>
        </div>
      </div>

      <div class="card sustain" style="margin-top:20px;">
        <img src="https://via.placeholder.com/500x200">
        <span class="tag">BREWING A BETTER WORLD</span>
        <h3>Sustentabilidade</h3>
        <p>Compromisso com meio ambiente e impacto social.</p>
      </div>

    </div>

    <!-- RIGHT -->
    <div>

      <div class="card culture">
        <h3>Cultura</h3>
        <p>Entenda os pilares que sustentam nosso ambiente.</p>
      </div>

      <div class="card process" style="margin-top:20px;">

        <div class="process-left">
          <span class="tag">EXCELÊNCIA TÉCNICA</span>
          <h3>Processo de Fabricação</h3>

          <div class="steps">

            <div class="step">
              <span class="number">01</span>
              <div>
                <strong>Puro Malte</strong>
                <p>A base da qualidade superior.</p>
              </div>
            </div>

            <div class="step">
              <span class="number">02</span>
              <div>
                <strong>Fermentação</strong>
                <p>Segredo do sabor equilibrado.</p>
              </div>
            </div>

          </div>

          <button class="btn">Ver infográfico</button>
        </div>

        <div class="process-right"></div>

      </div>

    </div>

  </div>

  <!-- FOOTER -->
  <div class="footer">
    <div class="quote">"Qualidade não é um ato, é um hábito."</div>
    <button class="btn btn-primary">Contribuir com a Wiki</button>
    <button class="btn btn-outline">Solicitar Tópico</button>
  </div>

</div>

</body>
</html>